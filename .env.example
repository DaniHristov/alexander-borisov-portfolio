# Designer Portfolio — environment variables
# Copy to .env.local and fill in. .env*.local is gitignored.

# --- Database: Neon Postgres (Vercel → Storage → Neon) ---
# The Vercel↔Neon integration sets this automatically in deployed envs.
# For local dev, copy the connection string from the Neon dashboard.
DATABASE_URL=

# --- Image storage: Vercel Blob (Vercel → Storage → Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- Auth: magic-link email via Resend (resend.com) ---
RESEND_API_KEY=
# Comma-separated list of emails allowed to request an admin login link.
ADMIN_EMAILS=
# Secret used to sign session cookies / magic-link tokens.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Base URL of the site (used to build magic-link callback URLs).
# Local: http://localhost:3000 — Production: https://<your-domain>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
